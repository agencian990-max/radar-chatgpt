# API key de OpenAI (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Modelo con soporte de web_search (opcional, este es el default)
OPENAI_MODEL=gpt-4.1

# Cadena de conexión a tu base de datos Postgres (la obtienes de Neon.tech)
DATABASE_URL=postgres://usuario:password@host/basededatos?sslmode=require

# Usuario y contraseña para entrar al dashboard
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=elige-una-clave-segura

# A qué hora corre el chequeo automático diario (formato cron, hora de Lima)
CRON_SCHEDULE=0 8 * * *

PORT=3000
